# Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to source control.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Upstash Redis (for API rate limiting) ---
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# --- OpenAI (for semantic search embeddings) ---
OPENAI_API_KEY=sk-...

# --- Vercel URL (auto-set on Vercel; set manually for local dev) ---
VERCEL_URL=localhost:3000

# --- Phase 4: personalization & delivery ---
# Public base URL used in email links and unsubscribe tokens
NEXT_PUBLIC_APP_URL=https://your-domain.com

# 32-char random secret for HMAC-SHA256 unsubscribe tokens
# Generate: openssl rand -hex 32
UNSUBSCRIBE_SECRET=replace-with-32-char-random-secret

# Resend API key for transactional email (weekly brief)
RESEND_API_KEY=re_...

# Clerk user ID of the admin account (grants access to /admin/usage)
ADMIN_USER_ID=user_...
