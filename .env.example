# =============================================================================
# AI News Intelligence — environment variables
# =============================================================================
# Copy this file to .env.local (Next.js picks it up automatically).
# .env.local is gitignored — NEVER commit it.
#
# Quick start (local Supabase via Docker):
#   npx supabase start        → gives you SUPABASE_URL and both keys below
# =============================================================================

# --- Session auth (no external service) --------------------------------------
# Generate both with: openssl rand -hex 32
AUTH_SECRET=replace-with-output-of-openssl-rand-hex-32
AUTH_PASSWORD=choose-a-strong-password

# --- Supabase ----------------------------------------------------------------
# URL is always needed (also used by the browser for realtime, if enabled)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Service role key — used by server-side API routes only (never sent to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (embeddings for semantic search) ---------------------------------
OPENAI_API_KEY=sk-...

# --- App URL -----------------------------------------------------------------
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Weekly email digest (optional — skip if you don't want email) -----------
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=replace-with-output-of-openssl-rand-hex-32
RESEND_API_KEY=re_...
