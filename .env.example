# =============================================================================
# AI News Intelligence — environment variables
# =============================================================================
# Copy this file to .env.local (Next.js picks it up automatically).
# .env.local is gitignored — NEVER commit it.
#
# For local development, Supabase can run in Docker:
#   npx supabase start   (gives you the SUPABASE_URL + ANON_KEY below)
# =============================================================================

# --- Session auth (no external service) --------------------------------------
# Generate both with: openssl rand -hex 32
# AUTH_SECRET must be at least 32 characters.
AUTH_SECRET=replace-with-output-of-openssl-rand-hex-32
AUTH_PASSWORD=choose-a-strong-password

# --- Supabase ----------------------------------------------------------------
# Local dev: run `npx supabase start` and copy the output values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# --- OpenAI (embeddings for semantic search) ---------------------------------
OPENAI_API_KEY=sk-...

# --- App URL (used in email unsubscribe links) --------------------------------
# Local: http://localhost:3000   Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Weekly email digest -----------------------------------------------------
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=replace-with-output-of-openssl-rand-hex-32
RESEND_API_KEY=re_...
