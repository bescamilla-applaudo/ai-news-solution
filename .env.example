# =============================================================================
# AI News Intelligence — Next.js environment variables
# =============================================================================
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — NEVER commit it.
# =============================================================================

# --- Supabase (local dev) ----------------------------------------------------
# Run `supabase start` to get these values, or use your hosted project.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Embed server (local sentence-transformers, no API key needed) -----------
# The Python embed server runs on port 8001.
# Start it with: python worker/embed_server.py
# Required for /search semantic search to work.
WORKER_EMBED_URL=http://localhost:8001

# --- App URL -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
