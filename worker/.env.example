# =============================================================================
# AI News Intelligence — Worker environment variables
# =============================================================================
# Copy this file to worker/.env and fill in values.
# worker/.env is gitignored — NEVER commit it.
# =============================================================================

# --- Supabase (service role — bypasses RLS; keep private) --------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenRouter (free LLM inference, no credit card required) ----------------
# 1. Create a free account at https://openrouter.ai
# 2. Go to https://openrouter.ai/keys and click "Create Key"
# 3. Paste the key below (starts with sk-or-v1-)
#
# Used by: worker/pipeline/graph.py (categorizer, evaluator, summarizer)
#          worker/tasks/weekly_brief.py (digest generation)
#
# Free models in use:
#   google/gemma-4-31b-it:free       — first-pass noise filter
#   nvidia/nemotron-3-super-120b-a12b:free — evaluator + summarizer
#
# No embeddings API key needed — embeddings run locally via sentence-transformers.
OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key

# --- Celery broker (Redis) ---------------------------------------------------
# Local: redis://localhost:6379/0
# Production (Upstash, TLS): rediss://:<token>@<host>:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Cost gate (daily token limit across all LLM calls) ----------------------
# With free OpenRouter models all calls are $0 — this is just a rate-limit safeguard.
DAILY_TOKEN_CAP=400000

# --- Weekly email digest (optional) -----------------------------------------
# Only needed if you want to receive the Monday morning email brief.
# Get a free Resend API key at https://resend.com (100 emails/day free).
RESEND_API_KEY=re_optional_replace_if_you_want_email
RESEND_FROM_EMAIL=brief@your-domain.com

# --- Unsubscribe tokens (weekly brief) --------------------------------------
# HMAC-SHA256 secret for generating secure unsubscribe links.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change-me-in-production

# Base URL for unsubscribe links in weekly brief emails.
APP_URL=http://localhost:3000

# --- Tracing (disabled — no external service required) ----------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_TRACING=false
