# Worker Environment Variables
# Copy to worker/.env and fill in values.
# In production these live in Railway dashboard — never in source control.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
UPSTASH_REDIS_URL=rediss://default:token@your-redis.upstash.io:6380
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-news-prod

# --- GitHub (Phase 3 scraper — PAT with public_repo scope) ---
GITHUB_TOKEN=ghp_...

# --- Cost cap (default: 400,000 tokens/day; override to tighten/loosen) ---
DAILY_TOKEN_CAP=400000

# --- Phase 4: weekly brief delivery ---
# Must match the value in the Next.js app .env
NEXT_PUBLIC_APP_URL=https://your-domain.com
UNSUBSCRIBE_SECRET=replace-with-32-char-random-secret
RESEND_API_KEY=re_...
