# =============================================================================
# AI News Intelligence — Worker environment variables
# =============================================================================
# Copy this file to worker/.env and fill in values.
# worker/.env is gitignored — NEVER commit it.
# =============================================================================

# --- Supabase (service role — bypasses RLS; keep private) --------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM APIs ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Celery broker (Redis) ---------------------------------------------------
# Local: redis://localhost:6379/0
# Production (Upstash, TLS): rediss://:<token>@<host>:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- GitHub scraper ----------------------------------------------------------
# Fine-Grained PAT with ONLY public_repo read access — no org/private repo scope
GITHUB_TOKEN=github_pat_...

# --- Cost gate (daily token limit across all LLM calls) ----------------------
DAILY_TOKEN_CAP=400000

# --- Weekly email digest -----------------------------------------------------
# Must match the value in the Next.js app .env.local
NEXT_PUBLIC_APP_URL=http://localhost:3000
UNSUBSCRIBE_SECRET=replace-with-output-of-openssl-rand-hex-32
RESEND_API_KEY=re_...

# --- Tracing (disabled for privacy) ------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_TRACING=false
